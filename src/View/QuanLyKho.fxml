<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="750.0" prefWidth="1100.0" styleClass="main-bg" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controll.BanHangController">
   
   <stylesheets>
      <URL value="@style.css" />
   </stylesheets>

   <top>
      <HBox alignment="CENTER" prefHeight="70.0" spacing="20.0" style="-fx-background-color: rgba(230, 126, 34, 0.9);">
         <children>
            <Label contentDisplay="RIGHT" text="QUẢN LÝ CỬA HÀNG ĐIỆN THOẠI" textAlignment="CENTER" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="26.0" />
               </font>
               <HBox.margin>
                  <Insets left="20.0" />
               </HBox.margin>
            </Label>
         </children>
      </HBox>
   </top>

   <center>
      <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
        <tabs>
          <Tab text="Bán hàng">
            <content>
              <AnchorPane minHeight="0.0" minWidth="0.0">
                     <children>
                        <HBox spacing="15.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                           <children>
                              <!-- BÊN TRÁI: DANH SÁCH VÀ GIỎ HÀNG -->
                              <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label alignment="CENTER" contentDisplay="CENTER" text="Danh sách sản phẩm" textAlignment="RIGHT" textFill="#157ee7">
                                       <font>
                                          <Font name="System Bold" size="18.0" />
                                       </font>
                                       <VBox.margin>
                                          <Insets left="90.0" />
                                       </VBox.margin>
                                    </Label>
                                    <TextField fx:id="txtTimKiem" promptText="🔍  Tìm theo tên, hãng..." />
                                    <TableView fx:id="tableSanPham" prefHeight="280.0" styleClass="glass-pane">
                                       <columns>
                                         <TableColumn fx:id="colMaSP" prefWidth="60.0" text="Mã SP" />
                                         <TableColumn fx:id="colTenSP" prefWidth="210.0" text="Tên SP" />
                                           <TableColumn fx:id="colGia" prefWidth="130.0" text="Đơn giá" />
                                           <TableColumn fx:id="colTonKho" prefWidth="70.0" text="Còn lại" />
                                           <TableColumn fx:id="colHang" prefWidth="100.0" text="Hãng" />
                                       </columns>
                                     </TableView>
                                    
                                    <Label text="Giỏ hàng" textFill="#2c3e50">
                                       <font>
                                          <Font name="System Bold" size="18.0" />
                                       </font>
                                       <VBox.margin>
                                          <Insets left="90.0" />
                                       </VBox.margin>
                                    </Label>
                                    <TableView fx:id="tableGioHang" prefHeight="200.0" styleClass="glass-pane">
                                       <columns>
                                         <TableColumn fx:id="colMaGio" prefWidth="60.0" text="Mã SP" />
                                         <TableColumn fx:id="colTenGio" prefWidth="210.0" text="Tên SP" />
                                           <TableColumn fx:id="colSLGio" prefWidth="70.0" text="SL" />
                                           <TableColumn fx:id="colGiaGio" prefWidth="130.0" text="Đơn giá" />
                                           <TableColumn fx:id="colThanhTien" prefWidth="130.0" text="Thành tiền" />
                                       </columns>
                                    </TableView>
                                    <Label fx:id="lblTongTien" maxWidth="1.7976931348623157E308" text="TỔNG TIỀN: 0 ₫" textFill="#c0392b">
                                       <font>
                                          <Font name="System Bold" size="16.0" />
                                       </font>
                                       <VBox.margin>
                                          <Insets top="4.0" />
                                       </VBox.margin>
                                    </Label>
                                 </children>
                              </VBox>
                              
                              <!-- BÊN PHẢI: CHI TIẾT VÀ THAO TÁC -->
                              <VBox prefWidth="350.0" spacing="15.0" styleClass="glass-pane">
                                 <padding>
                                    <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                                 </padding>
                                 <children>
                                    <Label alignment="CENTER" maxWidth="1.7976931348623157E308" text="Chi tiết sản phẩm" textFill="#e67e22">
                                       <font>
                                          <Font name="System Bold" size="20.0" />
                                       </font>
                                    </Label>
                                    
                                    <VBox spacing="8.0">
                                       <children>
                                          <Label text="Loại SP" />
                                          <ComboBox fx:id="cbLoaiSP" maxWidth="1.7976931348623157E308" promptText="-- Chọn loại --" />
                                          
                                          <Label text="Mã SP" />
                                          <TextField fx:id="txtMaSP" editable="false" styleClass="text-field-readonly" />
                                          
                                          <Label text="Tên SP" />
                                          <TextField fx:id="txtTenSP" editable="false" styleClass="text-field-readonly" />
                                          
                                          <Label text="Đơn giá" />
                                          <TextField fx:id="txtDonGia" editable="false" styleClass="text-field-readonly" />
                                          
                                          <Label text="Số lượng mua" />
                                          <TextField fx:id="txtSoLuongMua" text="1" />
                                       </children>
                                    </VBox>
                                    
                                    <Button fx:id="btnThemVaoGio" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleThemVaoGio" prefHeight="40.0" styleClass="button-orange" text="THÊM VÀO GIỎ" />
                                    
                                    <VBox alignment="CENTER" prefHeight="150.0" style="-fx-border-color: #ddd; -fx-background-color: white; -fx-background-radius: 5; -fx-border-radius: 5;">
                                       <children>
                                          <ImageView fx:id="imgPreview" fitHeight="130.0" fitWidth="130.0" pickOnBounds="true" preserveRatio="true" />
                                       </children>
                                    </VBox>
                                    
                                    <HBox spacing="10.0">
                                       <children>
                                          <Button fx:id="btnXoaKhoiGio" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleXoaKhoiGio" prefHeight="40.0" styleClass="button-red" text="XOÁ" HBox.hgrow="ALWAYS" />
                                          <Button fx:id="btnXuatHoaDon" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleXuatHoaDon" prefHeight="40.0" styleClass="button-green" text="XUẤT HOÁ ĐƠN" HBox.hgrow="ALWAYS" />
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                     </children>
                  </AnchorPane>
            </content>
          </Tab>
          <Tab fx:id="tabHoaDon" text="📋  Hoá đơn">
            <content>
              <fx:include source="LichSuHoaDon.fxml" />
            </content>
          </Tab>
          <!-- Tab chỉ dành cho ADMIN, sẽ bị ẩn nếu là STAFF -->
          <Tab fx:id="tabKho" text="📦  Quản lý kho">
            <content>
              <fx:include source="QuanLySanPham.fxml" />
            </content>
          </Tab>
        </tabs>
      </TabPane>
   </center>
</BorderPane>
