<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controll.LichSuHoaDonController">
    <children>
        <VBox spacing="10.0"
              AnchorPane.topAnchor="12.0" AnchorPane.bottomAnchor="12.0"
              AnchorPane.leftAnchor="12.0" AnchorPane.rightAnchor="12.0">
            <children>

                <!-- ===== TIÊU ĐỀ + THANH TÌM KIẾM ===== -->
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <Label text="LỊCH SỬ HÓA ĐƠN" textFill="#157ee7">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Label>
                        <TextField fx:id="txtTimKiem" prefWidth="300.0"
                                   promptText="🔍  Tìm theo tên KH, SĐT, nhân viên, mã đơn..."
                                   HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleLamMoi" prefHeight="34.0"
                                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 7; -fx-cursor: hand; -fx-font-weight: bold;"
                                text="🔄  Làm mới" />
                    </children>
                </HBox>

                <!-- ===== SPLIT PANE: bảng đơn hàng / chi tiết ===== -->
                <SplitPane dividerPositions="0.55" orientation="VERTICAL" VBox.vgrow="ALWAYS">
                    <items>

                        <!-- PHẦN TRÊN: DANH SÁCH ĐƠN HÀNG -->
                        <AnchorPane>
                            <children>
                                <TableView fx:id="tableDonHang" styleClass="glass-pane"
                                           AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                                           AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
                                    <columns>
                                        <TableColumn fx:id="colIdDon"    prefWidth="65.0"  text="Mã ĐH"       />
                                        <TableColumn fx:id="colNgay"     prefWidth="145.0" text="Ngày tạo"    />
                                        <TableColumn fx:id="colKhachHang" prefWidth="180.0" text="Khách hàng" />
                                        <TableColumn fx:id="colSdt"      prefWidth="120.0" text="SĐT"         />
                                        <TableColumn fx:id="colNhanVien" prefWidth="130.0" text="Nhân viên"   />
                                        <TableColumn fx:id="colTongTien" prefWidth="150.0" text="Tổng tiền"   />
                                    </columns>
                                    <placeholder>
                                        <Label text="Chưa có hóa đơn nào. Hãy thực hiện giao dịch đầu tiên!" />
                                    </placeholder>
                                </TableView>
                            </children>
                        </AnchorPane>

                        <!-- PHẦN DƯỚI: CHI TIẾT ĐƠN HÀNG ĐÃ CHỌN -->
                        <AnchorPane>
                            <children>
                                <VBox spacing="6.0"
                                      AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                                      AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
                                    <children>
                                        <Label fx:id="lblTieuDeChiTiet"
                                               text="— Chọn một đơn hàng để xem chi tiết —"
                                               textFill="#e67e22">
                                            <font><Font name="System Bold" size="13.0" /></font>
                                            <VBox.margin><Insets top="4.0" /></VBox.margin>
                                        </Label>

                                        <TableView fx:id="tableChiTiet" styleClass="glass-pane" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colTenSP"    prefWidth="340.0" text="Tên sản phẩm" />
                                                <TableColumn fx:id="colSoLuong"  prefWidth="90.0"  text="SL"           />
                                                <TableColumn fx:id="colDonGia"   prefWidth="155.0" text="Đơn giá"      />
                                                <TableColumn fx:id="colThanhTien" prefWidth="155.0" text="Thành tiền"  />
                                            </columns>
                                            <placeholder>
                                                <Label text="Chọn đơn hàng phía trên để xem sản phẩm" />
                                            </placeholder>
                                        </TableView>
                                    </children>
                                </VBox>
                            </children>
                        </AnchorPane>

                    </items>
                </SplitPane>

            </children>
        </VBox>
    </children>
</AnchorPane>
